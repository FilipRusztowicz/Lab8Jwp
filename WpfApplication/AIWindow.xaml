<Window x:Class="WpfApplication.AIWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Asystent AI" Height="450" Width="400">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        
        <ListBox x:Name="ListaWiadomosci" 
                 ItemsSource="{Binding historia}" 
                 Grid.Row="0" 
                 Margin="0,0,0,10"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="#F0F0F0" Margin="5" Padding="10" CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="{Binding Rola}" FontWeight="Bold" Foreground="DarkBlue" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding Tresc}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Text="{Binding WpisywanyTekst, UpdateSourceTrigger=PropertyChanged}" 
                     Grid.Column="0" 
                     Margin="0,0,10,0" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True" 
                     MaxHeight="100"
                     VerticalScrollBarVisibility="Auto"/>

            <Button Content="Wyślij" 
                    Command="{Binding WyslijCommand}" 
                    Grid.Column="1" 
                    Width="80" 
                    Height="35"
                    VerticalAlignment="Bottom"/>
        </Grid>
    </Grid>
</Window>